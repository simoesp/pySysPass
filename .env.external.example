# Existing MySQL/MariaDB sysPass database. URL-encode special characters in
# credentials before placing them in this SQLAlchemy URL.
PYSYSPASS_DATABASE_URL=mysql+pymysql://user:password@database.example:3306/syspass

# Generate independent values with: openssl rand -hex 32
PYSYSPASS_SECRET_KEY=replace-with-a-random-signing-secret
PYSYSPASS_ENCRYPTION_KEY=replace-with-a-random-encryption-key

# Copy passwordSalt from the PHP installation's app/config/config.xml.
SYSPASS_PASSWORD_SALT=replace-with-the-php-password-salt

# Host ports; change these if they conflict with an existing sysPass PHP stack.
PYSYSPASS_FRONTEND_PORT=8081
PYSYSPASS_BACKEND_PORT=8001
PYSYSPASS_DEBUG=false
